;; shadow-cljs build for the raster cljs/browser sandbox.
;; Run:  npx shadow-cljs watch app   then open http://localhost:8080
{:deps   {:aliases [:cljs]}
 :dev-http {8080 "public"}
 :builds
 {:app {:target     :browser
        :output-dir "public/js"
        :asset-path "/js"
        :modules    {:main {:init-fn sandbox.core/init}}
        :devtools   {:preloads [] :http-root "public" :http-port 8080}}}}
